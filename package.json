{
  "name": "habit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "powershell -NoProfile -Command \"$env:NEXT_DISABLE_WEBPACK_CACHE='1'; if (Test-Path .next) { Remove-Item -Recurse -Force .next }; npx next dev -p 3002\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "mkdir .tmp 2>nul & set TEMP=.tmp&& set TMP=.tmp&& tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.49.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
